# =============================================================================
# AutoFlow AI — environment template
# Copy this file to:
#   backend/.env     (required for API + database)
#   frontend/.env    (optional; see VITE_* below)
# =============================================================================

# --- Backend (Groq) ---
# Create a key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: override default chat model (default is llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Backend (Supabase) ---
# Project URL from Supabase Dashboard → Settings → API (full https://....supabase.co URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (same page). You may use SUPABASE_ANON_KEY instead of SUPABASE_KEY.
SUPABASE_KEY=your_supabase_anon_key_here

# --- Backend (server) ---
# PORT=5000

# --- Frontend (Vite; only variables prefixed with VITE_ are exposed to the browser) ---
# Base URL for API calls. In dev, Vite proxies /api to the backend (see frontend/vite.config.js).
# VITE_API_BASE=/api
